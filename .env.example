APP_NAME=FastAPI Template
APP_ENV=local
APP_DEBUG=false
APP_API_V1_PREFIX=/api/v1
APP_VERSION=0.1.0
APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fastapi_template
APP_DB_POOL_SIZE=10
APP_DB_MAX_OVERFLOW=20
APP_DB_POOL_TIMEOUT=30
APP_DB_POOL_RECYCLE=1800
APP_SECRET_KEY=change-me-with-a-long-random-secret
APP_ACCESS_TOKEN_EXPIRE_MINUTES=30
APP_DEFAULT_ADMIN_EMAIL=aditi.admin@example.com
APP_DEFAULT_ADMIN_PASSWORD=ChangeMe123!
